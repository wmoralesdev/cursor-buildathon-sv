# Convex + Clerk Auth
# Copy to .env.local and fill in values

# Public site URL (no trailing slash). Used for canonical URL, Open Graph, sitemap, and JSON-LD.
# Set in Vercel → Project → Settings → Environment Variables for Production (and Preview if needed).
# Example: https://cursor-buildathon-sv.vercel.app
VITE_SITE_URL=https://your-production-domain.example

# Convex: Run `npx convex dev` first to create project, then get URL from dashboard
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Clerk: From https://dashboard.clerk.com (API Keys)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# IMPORTANT: These must be set in the CONVEX DASHBOARD (Settings → Environment Variables):
#   CLERK_JWT_ISSUER_DOMAIN = <Issuer URL from Clerk JWT template "convex">
#   ADMIN_EMAILS = your@email.com (comma-separated for /admin access)
#
# Clerk Dashboard → JWT Templates → Convex template → Copy Issuer URL
